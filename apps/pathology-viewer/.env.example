# URL of the shared backend (apps/server).
# Default (no .env needed) is http://localhost:3001 for single-machine use.
#
# For TRUE cross-machine sharing, set this to your backend's public URL — e.g.
# a free host (Render/Railway) or a tunnel (cloudflared/ngrok) — on EVERY
# machine, then rebuild/restart the dev server:
#
#   VITE_API_URL=https://your-backend-host.example.com
#
# To use this file: copy it to ".env" in this folder and edit the value.
VITE_API_URL=http://localhost:3001
